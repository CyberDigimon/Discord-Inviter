# Secrets stay out of this public repo.
#
# Option 1 (recommended): set env vars when you run the bot
#   export DISCORD_TOKEN="your_bot_token"
#   npm start
#
# Option 2 (local dev): copy this file to `.env` and add your token there.
#   `.env` is gitignored and will not be pushed to GitHub.

# Optional: post invite notifications to a server channel (channel ID)
# NOTIFY_CHANNEL_ID=

# Set to false to disable DM notifications to inviters (enabled by default)
# NOTIFY_INVITER_DM=true

DISCORD_TOKEN=
