# Secrets stay out of this public repo.
#
# Windows: double-click install-everything.bat (creates .env for you),
# then paste your Bot Token below.
#
# Use Developer Portal → Bot → Reset Token / Copy
# Do NOT use Application ID, Public Key, or Client Secret.
# No spaces around the = sign.

DISCORD_TOKEN=

# Optional: register slash commands instantly in one server while developing
# GUILD_ID=1234567890123456789

# Optional: post invite notifications to one or more TEXT channels
# NOTIFY_CHANNEL_IDS=1234567890123456789,9876543210987654321
# NOTIFY_CHANNEL_ID=1234567890123456789

# Set to false to disable DM notifications to inviters (enabled by default)
# NOTIFY_INVITER_DM=true
